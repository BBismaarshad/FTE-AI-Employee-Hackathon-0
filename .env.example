# AI Employee Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Gmail API (for Gmail Watcher - Silver tier+)
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_TOKEN_PATH=/path/to/token.json

# WhatsApp (for WhatsApp Watcher - Silver tier+)
WHATSAPP_SESSION_PATH=/secure/path/session

# Bank API (for Finance Watcher - Gold tier+)
BANK_API_TOKEN=your_bank_api_token
BANK_API_URL=https://api.yourbank.com

# OpenAI/Anthropic API (if using API instead of Claude Code)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# Development Mode
DRY_RUN=true
MAX_EMAILS_PER_HOUR=10
MAX_PAYMENTS_PER_DAY=5
