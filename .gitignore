*.bak
*.cache

# ========================================
# Gold Tier - Additional Exclusions
# ========================================

# Facebook/Instagram session data
.ai-employee/facebook-session/
**/facebook-session/

# Odoo Docker volumes and data
docker/odoo/backups/*.sql
docker/odoo/backups/*.dump
docker/odoo/.env
docker/odoo/extra-addons/*
